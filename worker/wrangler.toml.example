# ADR-014 Worker deployment config — TEMPLATE. Copy to wrangler.toml (gitignored) and fill in.
# Claude Code does NOT deploy; this documents the shape for the owner.

name = "herbuno-formulator"
main = "src/index.js"
compatibility_date = "2026-07-19"

# App Proxy forwards https://<shop>/apps/formulator/* to this Worker. Configure the proxy in the
# Shopify custom app admin (subpath prefix "apps", subpath "formulator", proxy URL = this Worker).
# routes = [{ pattern = "herbuno.com/apps/formulator/*", zone_name = "herbuno.com" }]

# KV namespace holding the versioned bundles (manifest:current, identity:<v>, formgraph:<v>, matrix:<v>).
# Create with: wrangler kv namespace create HB_KV   then paste the id below.
[[kv_namespaces]]
binding = "HB_KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

# Durable Object — central, authoritative rate limiter (ADR-014 Step-2a BLOCKER 2).
# The Worker FAILS CLOSED (degraded) if this binding is absent.
[[durable_objects.bindings]]
name = "RATE_LIMITER"
class_name = "RateLimiterDurableObject"

[[migrations]]
tag = "v1"
new_classes = ["RateLimiterDurableObject"]

# SECRETS — do NOT put here. Set out of band (two separate secrets):
#   wrangler secret put SHOPIFY_APP_SECRET          # Shopify App Proxy shared secret
#   wrangler secret put SPECIFICATION_TOKEN_SECRET  # independent random secret for token signing
# Locally, use .dev.vars (gitignored):
#   SHOPIFY_APP_SECRET = "shpss_..."
#   SPECIFICATION_TOKEN_SECRET = "..."
